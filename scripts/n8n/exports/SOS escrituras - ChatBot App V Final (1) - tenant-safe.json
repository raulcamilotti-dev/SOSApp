                  {
                      "parameters":  {
                                         "jsCode":  "// â”€â”€ Normalize input from SOS App (robot.ts) â”€â”€\n// robot.ts sends: message, sessionId, user_id, channel, tenant_id,\n// phone, governance (full governance object from loadGovernanceRuntime)\n//\n// governance contains: channel, webhook_url, playbook, rules, tables,\n// handoff, state_steps, instructions_compact\n\nconst body = $json.body ?? $json;\nconst rawChannel = String(body.channel || \u0027app\u0027).toLowerCase();\n\nfunction mapChannel(ch) {\n  if (!ch || ch === \u0027app\u0027) return \u0027app_atendimento\u0027;\n  if (ch === \u0027operator\u0027 || ch === \u0027app_operador\u0027) return \u0027app_operador\u0027;\n  return ch;\n}\n\nconst channel = mapChannel(rawChannel);\nconst phone = body.phone || body.sessionId || body.session_id || body.telefone_wa || \u0027\u0027;\nconst governance = body.governance || null;\n\n// Extract governance compact text (already built by robot.ts)\nconst governanceCompact = governance?.instructions_compact || \u0027\u0027;\n\nreturn [{\n  json: {\n    body: body,\n    channel: channel,\n    phone: phone,\n    session_id: phone,\n    message: body.message || \u0027\u0027,\n    tenant_id: body.tenant_id || \u0027\u0027,\n    user_id: body.user_id || \u0027\u0027,\n    governanceCompact: governanceCompact,\n    governance: governance\n  }\n}];"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       784,
                                       272
                                   ],
                      "id":  "cad7abaa-2c01-4049-a323-fc4b3a23c4ad",
                      "name":  "Normalize Input"
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT\n  a.system_prompt,\n  a.model,\n  a.temperature,\n  a.max_tokens\nFROM agents a\nWHERE a.tenant_id = NULLIF(\u0027{{ $(\u0027Normalize Input\u0027).item.json.tenant_id }}\u0027, \u0027\u0027)::uuid\n  AND COALESCE(a.is_default, true) = true\n  AND COALESCE(a.is_active, true) = true\n  AND a.deleted_at IS NULL\nORDER BY a.updated_at DESC NULLS LAST\nLIMIT 1;",
                                         "options":  {

                                                     }
