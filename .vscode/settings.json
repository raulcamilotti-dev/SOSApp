    "source.sortMembers": "explicit"
  },
  "terminal.integrated.sendKeybindingsToShell": true,
  "chat.tools.terminal.autoApprove": {
    "&": true,
    "npx tsc": true
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
